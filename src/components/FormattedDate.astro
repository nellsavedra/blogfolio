---
export interface Props {
    date: Date;
}

const { date } = Astro.props;
---

<time datetime={date.toISOString()}>
    {
        date.toLocaleDateString("es-es", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "2-digit",
        })
    }
</time>
